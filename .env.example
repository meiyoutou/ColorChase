CC_SMTP_HOST=smtp.qq.com
CC_SMTP_USER=your-email@example.com
CC_SMTP_PASS=your-smtp-authorization-code

COLORCHASE_ENV=production
COLORCHASE_SECRET_KEY=replace-with-a-long-random-secret
# 必填：本地和生产都必须使用 MySQL，不支持 SQLite fallback。
COLORCHASE_DATABASE_URL=mysql+aiomysql://colorchase:replace-password@127.0.0.1:3306/colorchase
COLORCHASE_ALLOWED_ORIGINS=https://colorchase.meiyoutou.top,https://ColorChase.meiyoutou.top
COLORCHASE_ALLOWED_HOSTS=colorchase.meiyoutou.top,ColorChase.meiyoutou.top

COLORCHASE_UPLOAD_MAX_BYTES=10485760
COLORCHASE_IMAGE_ORIGINAL_UPLOAD_MAX_BYTES=314572800
COLORCHASE_VIDEO_UPLOAD_MAX_BYTES=314572800
COLORCHASE_UPLOAD_RATE_LIMIT=30
COLORCHASE_AI_RATE_LIMIT=12
COLORCHASE_GLOBAL_AI_CONCURRENCY=4
COLORCHASE_USER_AI_CONCURRENCY=2

# 鏈湴绠＄悊鍛樺伐鍏峰紑鍏筹紙鐢熶骇鐜榛樿鍏抽棴锛岃涓?1 鍚敤锛?COLORCHASE_ENABLE_LOCAL_ADMIN_TOOLS=0

# NeuralPreset 妯″瀷鏍圭洰褰曪紙鍙€夛紝榛樿浣跨敤 model_assets/neural_preset/锛?# COLORCHASE_NEURALPRESET_ROOT=/opt/colorchase/neural_preset_src
